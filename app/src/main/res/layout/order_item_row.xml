<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/orderDateTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Date: 2023-10-27"
                android:textColor="#757575"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/orderStatusTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:background="#E8F5E9"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text="Pending"
                android:textColor="#4CAF50"
                android:textStyle="bold" />
        </RelativeLayout>

        <TextView
            android:id="@+id/orderCustomerTv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Customer: Loading..."
            android:textColor="#000000"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/orderContactTv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Contact: Loading..."
            android:textColor="#555555"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/orderItemsTv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Items: Idly x2, Dosa x1"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/orderAddressTv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Address: Loading..."
            android:textColor="#555555"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/orderPaymentTv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Payment: COD"
            android:textColor="#555555"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/orderTotalTv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Total: ₹150"
            android:textColor="#000000"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>
</androidx.cardview.widget.CardView>