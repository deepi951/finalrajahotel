<?xml version="1.0" encoding="utf-8"?>

<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background Image -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/hotel_bg"
        android:scaleType="centerCrop" />

    <!-- Overlay (for better readability) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000" />

    <!-- Menu Content -->
    <LinearLayout
        android:orientation="vertical"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <TextView
            android:text="Sri Raja Hotel Menu"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="40dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- VEG MENU -->
        <Button
            android:id="@+id/vegMenuBtn"
            android:text="Veg Menu 🌱"
            android:textSize="16sp"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="15dp"/>

        <!-- NON-VEG MENU -->
        <Button
            android:id="@+id/nonVegMenuBtn"
            android:text="Non-Veg Menu 🍗"
            android:textSize="16sp"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="15dp"/>

        <!-- VIEW CART -->
        <Button
            android:id="@+id/viewCartBtn"
            android:text="View Cart 🛒"
            android:textSize="16sp"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="15dp"/>

        <!-- CATERING BOOKING -->
        <Button
            android:id="@+id/cateringBtn"
            android:text="Catering Booking 🍽️"
            android:textSize="16sp"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="15dp"/>

        <!-- MY CATERING BOOKINGS -->
        <Button
            android:id="@+id/myCateringBtn"
            android:text="My Catering Bookings 📋"
            android:textSize="16sp"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="15dp"/>

    </LinearLayout>

</FrameLayout>